# ============================================================
# fortunel-observer - environment variable template
# ============================================================
# Copy to .env.local for local dev. Never commit .env.local.
# Production secrets live in Wrangler / Doppler / VPS .env.
# ============================================================

# --- Database -------------------------------------------------
# Dev (Docker Postgres via infra/dev/docker-compose.yml):
DATABASE_URL=postgres://dev:dev@localhost:5432/platform_dev

# Phase A-C prod (Neon):
# DATABASE_URL=postgres://<user>:<pass>@<host>.neon.tech/<db>?sslmode=require

# Phase D+ prod (Cloudflare Hyperdrive -> VPS Postgres):
# DATABASE_URL=<hyperdrive binding via wrangler.toml>

# --- Auth -----------------------------------------------------
# Better Auth secret: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-32-byte-hex
BETTER_AUTH_URL=http://localhost:8787

# GitHub OAuth (optional, register app at github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Email (Resend) -------------------------------------------
# Get key at resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@example.com

# --- Cloudflare -----------------------------------------------
# For local dev these are loaded via wrangler.toml / .dev.vars
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Storage (R2) ---------------------------------------------
R2_BUCKET_NAME=fortunel-assets
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=

# --- Observability --------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info

# --- Trading bot (Phase D, in apps/bot) -----------------------
# Exchange API keys (read-only first, trading later)
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Telegram notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Platform API (bot posts signals here)
PLATFORM_API_URL=http://localhost:8787
PLATFORM_API_KEY=

# --- VPS prod stack (Phase D, infra/prod-vps/.env) ------------
# Used by docker-compose on VPS - never put in app code
DB_PASSWORD=
AGE_PUBLIC_KEY=
R2_BACKUP_BUCKET=fortunel-backups
