# --- Postgres -----------------------------------------------
DB_USER=postgres
DB_PASSWORD=replace-with-strong-password
DB_NAME=platform

# --- Backup encryption --------------------------------------
# Generate with: age-keygen -o ~/age-key.txt && grep '^# public' ~/age-key.txt
# Store private key OFF this VPS.
AGE_PUBLIC_KEY=age1...

# --- R2 (rclone) --------------------------------------------
# rclone remote name configured for Cloudflare R2.
R2_REMOTE=r2
R2_BUCKET=fortunel-backups

# --- Bot --------------------------------------------------
# .env.bot lives next to this file; loaded by the bot service via env_file.
