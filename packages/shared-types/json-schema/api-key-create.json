{
  "$ref": "#/definitions/apiKeyCreateSchema",
  "definitions": {
    "apiKeyCreateSchema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "posts:read",
              "posts:write",
              "projects:read",
              "projects:write",
              "contact:read",
              "contact:write",
              "signals:read",
              "signals:write",
              "*:*"
            ]
          },
          "minItems": 1
        },
        "expires_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "scopes"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
