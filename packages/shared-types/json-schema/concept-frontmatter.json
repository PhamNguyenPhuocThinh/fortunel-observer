{
  "$ref": "#/definitions/conceptFrontmatterSchema",
  "definitions": {
    "conceptFrontmatterSchema": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "concept"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "related_concepts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300,
            "pattern": "^[a-zA-Z0-9._\\-/]+$"
          },
          "maxItems": 50,
          "default": []
        },
        "sources": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "format": "uri",
                "maxLength": 2048
              },
              {
                "$ref": "#/definitions/conceptFrontmatterSchema/properties/related_concepts/items"
              }
            ]
          },
          "maxItems": 50,
          "default": []
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "maxItems": 20,
          "default": []
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "published",
            "archived"
          ],
          "default": "draft"
        }
      },
      "required": [
        "type",
        "name",
        "summary"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
