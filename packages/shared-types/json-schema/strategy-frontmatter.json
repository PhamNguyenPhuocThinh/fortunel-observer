{
  "$ref": "#/definitions/strategyFrontmatterSchema",
  "definitions": {
    "strategyFrontmatterSchema": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "strategy"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "default": {}
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "maxItems": 50,
          "default": []
        },
        "regimes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "maxItems": 20,
          "default": []
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "live",
            "paused",
            "retired"
          ],
          "default": "draft"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "maxItems": 20,
          "default": []
        },
        "lifecycle_status": {
          "type": "string",
          "enum": [
            "draft",
            "published",
            "archived"
          ],
          "default": "draft"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
