{
  "$ref": "#/definitions/apiKeySchema",
  "definitions": {
    "apiKeySchema": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "owner_id": {
          "$ref": "#/definitions/apiKeySchema/properties/id"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "key_prefix": {
          "type": "string"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "posts:read",
              "posts:write",
              "projects:read",
              "projects:write",
              "contact:read",
              "contact:write",
              "signals:read",
              "signals:write",
              "*:*"
            ]
          }
        },
        "last_used_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "anyOf": [
            {
              "$ref": "#/definitions/apiKeySchema/properties/last_used_at/anyOf/0"
            },
            {
              "type": "null"
            }
          ]
        },
        "created_at": {
          "$ref": "#/definitions/apiKeySchema/properties/last_used_at/anyOf/0"
        },
        "revoked_at": {
          "anyOf": [
            {
              "$ref": "#/definitions/apiKeySchema/properties/last_used_at/anyOf/0"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "owner_id",
        "name",
        "key_prefix",
        "scopes",
        "last_used_at",
        "expires_at",
        "created_at",
        "revoked_at"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
